<UserControl x:Class="BcrRobotVision.Pages.ReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgMain}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="260"/>
        </Grid.RowDefinitions>

        <!-- 顶部统计 -->
        <Border Grid.Row="0"
                Style="{StaticResource IndustrialCardStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="总数" Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="txtTotal" Text="0" Foreground="{StaticResource TextMain}" FontSize="26" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="OK数" Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="txtOk" Text="0" Foreground="{StaticResource OkGreen}" FontSize="26" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="NG数" Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="txtNg" Text="0" Foreground="{StaticResource DangerRed}" FontSize="26" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="良率" Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="txtYield" Text="0%" Foreground="{StaticResource AccentBlue}" FontSize="26" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="平均值" Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="txtAverage" Text="0.000" Foreground="{StaticResource TextMain}" FontSize="24" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="5">
                    <TextBlock Text="标准差" Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="txtStdDev" Text="0.000" Foreground="{StaticResource TextMain}" FontSize="24" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock Text="CPK" Style="{StaticResource LabelTextStyle}"/>
                    <TextBlock x:Name="txtCpk" Text="0.000" Foreground="{StaticResource AccentBlue}" FontSize="24" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="刷新报表"
                            Width="100"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,10,0"
                            Click="BtnRefresh_Click"/>

                    <Button Content="导出CSV"
                            Width="100"
                            Style="{StaticResource IndustrialButtonStyle}"
                            Click="BtnExportCsv_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 折线图 -->
        <Border Grid.Row="1"
                Style="{StaticResource IndustrialCardStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="检测值折线图"
                           Style="{StaticResource SectionTitleStyle}"/>

                <Canvas x:Name="chartCanvas"
                        Grid.Row="1"
                        Background="#050B12"
                        SizeChanged="ChartCanvas_SizeChanged"/>
            </Grid>
        </Border>

        <!-- 数据表 -->
        <Border Grid.Row="2"
                Style="{StaticResource IndustrialCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="检测明细"
                           Style="{StaticResource SectionTitleStyle}"/>

                <DataGrid x:Name="dataGrid"
          Grid.Row="1"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          FontSize="14"
          RowHeight="34"

          Background="#071524"
          Foreground="#EAF6FF"

          BorderBrush="#1E6AA8"
          BorderThickness="1"

          GridLinesVisibility="Horizontal"

          RowBackground="#0B1C2E"
          AlternatingRowBackground="#10263B"

          HorizontalGridLinesBrush="#1E3E5A"
          VerticalGridLinesBrush="#1E3E5A">

                    <!-- 表头样式 -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"
                    Value="#103B60"/>
                            <Setter Property="Foreground"
                    Value="White"/>
                            <Setter Property="FontSize"
                    Value="15"/>
                            <Setter Property="FontWeight"
                    Value="Bold"/>
                            <Setter Property="Height"
                    Value="38"/>
                            <Setter Property="BorderBrush"
                    Value="#1E6AA8"/>
                            <Setter Property="BorderThickness"
                    Value="1"/>
                            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- 行样式 -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground"
                    Value="#DDEFFF"/>
                            <Setter Property="Background"
                    Value="#0B1C2E"/>

                            <Style.Triggers>

                                <!--鼠标悬停-->
                                <Trigger Property="IsMouseOver"
                         Value="True">
                                    <Setter Property="Background"
                            Value="#163B59"/>
                                </Trigger>

                                <!--选中-->
                                <Trigger Property="IsSelected"
                         Value="True">
                                    <Setter Property="Background"
                            Value="#0E5A9C"/>
                                    <Setter Property="Foreground"
                            Value="White"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>


                    <DataGrid.Columns>

                        <DataGridTextColumn Header="序号"
                            Binding="{Binding Index}"
                            Width="70"/>

                        <DataGridTextColumn Header="时间"
                            Binding="{Binding Time}"
                            Width="180"/>

                        <DataGridTextColumn Header="模式"
                            Binding="{Binding Mode}"
                            Width="100"/>

                        <DataGridTextColumn Header="拍照位"
                            Binding="{Binding CameraNo}"
                            Width="90"/>

                        <DataGridTextColumn Header="结果码"
                            Binding="{Binding ResultCode}"
                            Width="90"/>

                        <DataGridTextColumn Header="结果"
                            Binding="{Binding ResultText}"
                            Width="90"/>

                        <DataGridTextColumn Header="检测值"
                            Binding="{Binding MeasureValue,StringFormat=F3}"
                            Width="120"/>

                        <DataGridTextColumn Header="上限"
                            Binding="{Binding UpperLimit,StringFormat=F3}"
                            Width="100"/>

                        <DataGridTextColumn Header="下限"
                            Binding="{Binding LowerLimit,StringFormat=F3}"
                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>