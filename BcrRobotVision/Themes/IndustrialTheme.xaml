<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 颜色 -->
    <SolidColorBrush x:Key="BgMain" Color="#07111F"/>
    <SolidColorBrush x:Key="BgPanel" Color="#0D1B2D"/>
    <SolidColorBrush x:Key="BgPanelLight" Color="#102238"/>
    <SolidColorBrush x:Key="BorderBlue" Color="#2C4E70"/>
    <SolidColorBrush x:Key="AccentBlue" Color="#00BFFF"/>
    <SolidColorBrush x:Key="ButtonBlue" Color="#0078FF"/>
    <SolidColorBrush x:Key="TextMain" Color="#EAF4FF"/>
    <SolidColorBrush x:Key="TextSub" Color="#8AA4BC"/>
    <SolidColorBrush x:Key="DangerRed" Color="#FF4D4F"/>
    <SolidColorBrush x:Key="OkGreen" Color="#2EE88B"/>

    <!-- 标题文字 -->
    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>

    <Style x:Key="LabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- 卡片面板 -->
    <Style x:Key="IndustrialCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgPanel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBlue}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- 输入框 -->
    <Style x:Key="IndustrialTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="36"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBlue}"/>
        <Setter Property="Background" Value="#101C2C"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBlue}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- 按钮 -->
    <Style x:Key="IndustrialButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#17263A"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBlue}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="12,0"/>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource IndustrialButtonStyle}">
        <Setter Property="Background" Value="{StaticResource ButtonBlue}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
    </Style>

    <!-- CheckBox -->
    <Style x:Key="IndustrialCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- 日志框 -->
    <Style x:Key="LogTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource IndustrialTextBoxStyle}">
        <Setter Property="Height" Value="260"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <!-- 左侧导航按钮：默认样式 -->
    <Style x:Key="NavButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource IndustrialButtonStyle}">
        <Setter Property="Height" Value="70"/>
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Background" Value="#17263A"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBlue}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- 左侧导航按钮：选中样式 -->
    <Style x:Key="NavButtonSelectedStyle"
       TargetType="Button"
       BasedOn="{StaticResource NavButtonStyle}">
        <Setter Property="Background" Value="{StaticResource ButtonBlue}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

</ResourceDictionary>