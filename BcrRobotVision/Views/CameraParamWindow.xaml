<Window x:Class="BcrRobotVision.Views.CameraParamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="相机参数"
        Height="520"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F6F8">
    <Grid Margin="15">
        <Border Background="White" CornerRadius="8" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="触发模式" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbCaptureMode" Grid.Row="0" Grid.Column="1" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="抓取模式" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbTransMode" Grid.Row="1" Grid.Column="1" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="数据类型" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbDataType" Grid.Row="2" Grid.Column="1" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="抓取线数" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtGrabLineNum" Grid.Row="3" Grid.Column="1" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="回调线数" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtCallbackLineNum" Grid.Row="4" Grid.Column="1" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="曝光" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtExpo" Grid.Row="5" Grid.Column="1" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="帧率" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtFrame" Grid.Row="6" Grid.Column="1" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="最大帧率" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtMaxFrame" Grid.Row="7" Grid.Column="1" Margin="0,4,0,4" IsReadOnly="True"/>
                </Grid>

                <WrapPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,18,0,0">
                    <Button Content="读取参数"
                            Width="110"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="BtnLoad_Click"/>
                    <Button Content="保存参数"
                            Width="110"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="BtnSave_Click"/>
                    <Button Content="关闭"
                            Width="110"
                            Height="36"
                            Click="BtnClose_Click"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>