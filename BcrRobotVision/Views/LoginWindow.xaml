<Window x:Class="BcrRobotVision.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="博创机器人"
        Width="900"
        Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        >

	<Window.Resources>
		<Style x:Key="InputBoxStyle" TargetType="TextBox">
			<Setter Property="Height" Value="42"/>
			<Setter Property="FontSize" Value="15"/>
			<Setter Property="Foreground" Value="#EAF4FF"/>
			<Setter Property="CaretBrush" Value="#00D8FF"/>
			<Setter Property="Background" Value="#101C2C"/>
			<Setter Property="BorderBrush" Value="#315A7D"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="12,0"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
			<Setter Property="Height" Value="42"/>
			<Setter Property="FontSize" Value="15"/>
			<Setter Property="Foreground" Value="#EAF4FF"/>
			<Setter Property="CaretBrush" Value="#00D8FF"/>
			<Setter Property="Background" Value="#101C2C"/>
			<Setter Property="BorderBrush" Value="#315A7D"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="12,0"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<Style x:Key="BlueButtonStyle" TargetType="Button">
			<Setter Property="Height" Value="42"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Background" Value="#006DFF"/>
			<Setter Property="BorderBrush" Value="#18D7FF"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>

		<Style x:Key="DarkButtonStyle" TargetType="Button">
			<Setter Property="Height" Value="42"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Foreground" Value="#DDEBFF"/>
			<Setter Property="Background" Value="#17263A"/>
			<Setter Property="BorderBrush" Value="#3B5674"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
	</Window.Resources>

	<Border CornerRadius="14"
            Background="#081523"
            BorderBrush="#315A7D"
            BorderThickness="1"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="390"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- 左侧工业背景 -->
			<Border Grid.Column="0"
                    CornerRadius="14,0,0,14"
                    Background="#07111F">
				<Grid>
					<Rectangle Opacity="0.18">
						<Rectangle.Fill>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="#0A8FFF" Offset="0"/>
								<GradientStop Color="#00101F" Offset="1"/>
							</LinearGradientBrush>
						</Rectangle.Fill>
					</Rectangle>

					<StackPanel VerticalAlignment="Center" Margin="36,0">
						<Border Width="110"
                                Height="110"
                                CornerRadius="20"
                                BorderBrush="#1BD8FF"
                                BorderThickness="1"
                                Background="#102238"
                                HorizontalAlignment="Left">
                            <Image Source="/Assets/favicon.png"
                            Width="82"
                            Height="82"
                            Stretch="Uniform"/>
                        </Border>

						<TextBlock Text="BCR VISION"
                                   Foreground="#7FDFFF"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,28,0,6"/>

						<TextBlock Text="工业视觉检测与安装控制平台"
                                   Foreground="#D9EEFF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

						<TextBlock Text="3D Camera · Motion Control · PLC · Halcon"
                                   Foreground="#7C93A8"
                                   FontSize="13"
                                   Margin="0,18,0,0"/>
					</StackPanel>
				</Grid>
			</Border>

			<!-- 右侧登录面板 -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="48"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<!-- 顶部按钮 -->
				<Grid Grid.Row="0">
					<TextBlock Text="博创机器人"
                               Foreground="#EAF4FF"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="22,0,0,0"/>

					<StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
						<Button Content="—"
                                Width="36"
                                Height="28"
                                Background="Transparent"
                                Foreground="#DDEBFF"
                                BorderThickness="0"
                                FontSize="18"
                                Click="BtnMin_Click"/>
						<Button Content="×"
                                Width="36"
                                Height="28"
                                Background="Transparent"
                                Foreground="#DDEBFF"
                                BorderThickness="0"
                                FontSize="20"
                                Click="BtnExit_Click"/>
					</StackPanel>
				</Grid>

				<Border Grid.Row="1"
                        Width="390"
                        Height="390"
                        CornerRadius="12"
                        Background="#0D1B2D"
                        BorderBrush="#2C4E70"
                        BorderThickness="1"
                        Padding="34"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

					<StackPanel>
						<TextBlock Text="用户登录"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

						<TextBlock Text="智能检测与安装控制平台"
                                   Foreground="#7C93A8"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,30"/>

						<TextBlock Text="用户名"
                                   Foreground="#AFC4D8"
                                   FontSize="13"
                                   Margin="0,0,0,6"/>
						<TextBox x:Name="txtUserName"
                                 Style="{StaticResource InputBoxStyle}"/>

						<TextBlock Text="密码"
                                   Foreground="#AFC4D8"
                                   FontSize="13"
                                   Margin="0,16,0,6"/>
						<PasswordBox x:Name="txtPassword"
                                     Style="{StaticResource PasswordBoxStyle}"/>

						<Grid Margin="0,24,0,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition/>
								<ColumnDefinition Width="16"/>
								<ColumnDefinition/>
							</Grid.ColumnDefinitions>

							<Button Grid.Column="0"
                                    Content="登录"
                                    Style="{StaticResource BlueButtonStyle}"
                                    Click="BtnLogin_Click"/>

							<Button Grid.Column="2"
                                    Content="退出"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Click="BtnExit_Click"/>
						</Grid>

						<TextBlock Text="默认账号：admin / admin"
                                   Foreground="#526B82"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,22,0,0"/>
					</StackPanel>
				</Border>
			</Grid>
		</Grid>
	</Border>
</Window>