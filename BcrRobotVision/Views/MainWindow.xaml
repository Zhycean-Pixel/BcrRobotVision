<Window x:Class="BcrRobotVision.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="博创机器人"
        Width="1450"
        Height="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgMain}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部栏 -->
        <Border Grid.Row="0"
                Background="#0B2038"
                BorderBrush="{StaticResource BorderBlue}"
                BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="博创机器人"
                           Style="{StaticResource TitleTextStyle}"
                           VerticalAlignment="Center"
                           Margin="24,0,0,0"/>

                <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,28,0">

                    <TextBlock Text="运行模式："
               Foreground="#5CC8FF"
               FontSize="19"
               FontWeight="Bold"
               VerticalAlignment="Center"
               Margin="0,0,12,0"/>

                    <ComboBox x:Name="cmbRunMode"
              Width="190"
              Height="42"
              FontSize="18"
              FontWeight="Bold"
              Foreground="#111111"
              Background="#A8D9FF"
              BorderBrush="#28A7FF"
              BorderThickness="1.5"
              SelectedIndex="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              SelectionChanged="CmbRunMode_SelectionChanged">

                        <ComboBox.Resources>

                            <!-- 下拉背景彻底去白 -->
                            <SolidColorBrush
                x:Key="{x:Static SystemColors.WindowBrushKey}"
                Color="#A8D9FF"/>

                            <Style TargetType="ComboBoxItem">

                                <!-- 黑色字体 -->
                                <Setter Property="Foreground"
                        Value="#111111"/>

                                <!-- 默认浅蓝背景 -->
                                <Setter Property="Background"
                        Value="#A8D9FF"/>

                                <Setter Property="FontSize"
                        Value="18"/>

                                <Setter Property="FontWeight"
                        Value="Bold"/>

                                <Setter Property="Padding"
                        Value="0,10"/>

                                <Setter Property="HorizontalContentAlignment"
                        Value="Center"/>

                                <Setter Property="VerticalContentAlignment"
                        Value="Center"/>

                                <Setter Property="Template">
                                    <Setter.Value>

                                        <ControlTemplate TargetType="ComboBoxItem">

                                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#5AAFE3"
                                    BorderThickness="0,0,0,1">

                                                <ContentPresenter
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>

                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <!-- 鼠标悬停 -->
                                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="#67C2FF"/>
                                                </Trigger>

                                                <!-- 选中 -->
                                                <Trigger Property="IsSelected"
                                         Value="True">
                                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="#40B4FF"/>
                                                </Trigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                    </Setter.Value>
                                </Setter>

                            </Style>

                        </ComboBox.Resources>

                        <ComboBoxItem Content="全部正面"/>
                        <ComboBoxItem Content="全部反面"/>

                    </ComboBox>

                </StackPanel>
            </Grid>
        </Border>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Border Grid.Column="0"
                    Background="#081523"
                    BorderBrush="{StaticResource BorderBlue}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="14">
                    <Button x:Name="btnCameraNav"
                  Content="相机检测"
                  Style="{StaticResource NavButtonSelectedStyle}"
                  Margin="0,0,0,20"
                  Click="BtnCameraPage_Click"/>

                    <Button x:Name="btnPlcNav"
                     Content="PLC通信"
                     Style="{StaticResource NavButtonSelectedStyle}"
                     Margin="0,0,0,20"
                    Click="BtnPlcPage_Click"/>

                    <Button Content="报表曲线"
                            Style="{StaticResource NavButtonSelectedStyle}"
                            Margin="0,0,0,20"
                            Click="BtnReportPage_Click"/>
                    <Button Content="CPK / SPC"
            Style="{StaticResource NavButtonSelectedStyle}"
            Margin="0,0,0,20"
            Click="BtnSpcPage_Click"/>

                    <Button Content="系统参数"
                            Style="{StaticResource NavButtonSelectedStyle}"
                            Margin="0,0,0,20"/>
                </StackPanel>
            </Border>

            <!-- 内容区 -->
            <ContentControl x:Name="MainContent"
                            Grid.Column="1"
                            Margin="16"/>
        </Grid>
    </Grid>
</Window>